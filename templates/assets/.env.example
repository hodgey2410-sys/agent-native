# Server port (production)
PORT=3000

# Builder-managed image generation is enabled by default.
# Set this to false only to force the manual Gemini fallback.
BUILDER_IMAGE_GENERATION_ENABLED=true

# Gemini is used for video generation and as the manual image fallback.
GEMINI_API_KEY=

# OpenAI can be used as a manual image generation fallback.
OPENAI_API_KEY=

# S3-compatible object storage for originals, thumbnails, videos, and exports.
ASSETS_STORAGE_BUCKET=
ASSETS_STORAGE_REGION=auto
ASSETS_STORAGE_ENDPOINT=
ASSETS_STORAGE_PUBLIC_BASE_URL=
ASSETS_STORAGE_ACCESS_KEY_ID=
ASSETS_STORAGE_SECRET_ACCESS_KEY=

# Custom health check message
PING_MESSAGE=pong
